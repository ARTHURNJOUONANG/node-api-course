# Copier ce fichier en .env et renseigner les valeurs.

# Port d'écoute (défaut 3000)
PORT=3000

# Environnement Node (development | production)
NODE_ENV=development

# SQLite — chemin relatif au dossier prisma/
DATABASE_URL="file:./prisma/dev.db"

# Secret pour signer les JWT (chaîne longue et aléatoire en production)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION

# Durée de validité du token JWT (ex: 24h, 7d)
JWT_EXPIRES_IN=24h

# CORS — en production, liste d'origines séparées par des virgules (optionnel)
# CORS_ORIGINS=http://localhost:5173,https://mon-frontend.com
